# ═══════════════════════════════════════════════════════════════════
# CV Intelligence Layer (this app)
# ═══════════════════════════════════════════════════════════════════
APP_ENV=development
APP_PORT=8001
APP_API_KEY=dev_key_change_me
UPLOAD_DIR=/tmp/cv_uploads
MAX_FILE_SIZE_MB=20
OCR_DPI=200
OCR_CONFIDENCE_THRESHOLD=0.6
# Set EASYOCR_GPU=true to run EasyOCR on GPU (requires CUDA-enabled torch and
# nvidia-container-toolkit on the host). Default false keeps OCR on CPU.
EASYOCR_GPU=true
# Build-time arg passed to docker-compose: "cpu" for CPU-only PyTorch wheels,
# "cu121" or "cu118" for CUDA-enabled wheels. Must match host CUDA runtime.
CUDA_VERSION=cu121
FASTTEXT_MODEL_PATH=/models/lid.176.bin
RANKING_DEFAULT_RECALL_SIZE=30
RANKING_LLM_CONCURRENCY=5

# ═══════════════════════════════════════════════════════════════════
# PostgreSQL + Redis (infrastructure)
# ═══════════════════════════════════════════════════════════════════
DATABASE_URL=postgresql+asyncpg://cv_user:password@localhost:5432/cv_intelligence
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0

# ═══════════════════════════════════════════════════════════════════
# Semantic Search API (external service)
# ═══════════════════════════════════════════════════════════════════
SEARCH_API_BASE_URL=http://localhost:80
SEARCH_API_KEY=search_api_key
# SEARCH_INGEST_API_KEY=sk_ingest_...
SEARCH_WEBHOOK_SECRET=change_me_search_webhook_secret

# ═══════════════════════════════════════════════════════════════════
# LLM — Google Gemini (or OpenAI-compatible local)
# ═══════════════════════════════════════════════════════════════════
LLM_PROVIDER=gemini
LLM_API_KEY=gemini_key
LLM_MODEL=gemini-2.5-flash
# LLM_BASE_URL=http://localhost:11434/v1

# ═══════════════════════════════════════════════════════════════════
# Hiring Platform (external consumer)
# ═══════════════════════════════════════════════════════════════════
APP_WEBHOOK_SECRET=change_me_app_webhook_secret
WEBHOOK_TIMEOUT_SECONDS=10
