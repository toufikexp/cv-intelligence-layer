APP_ENV=development
APP_PORT=8001

DATABASE_URL=postgresql+asyncpg://cv_user:password@localhost:5432/cv_intelligence
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0

# CV Intelligence Layer API key (simple shared key for now)
APP_API_KEY=dev_key_change_me

SEARCH_API_BASE_URL=http://localhost:80
SEARCH_API_KEY=search_api_key
# Optional: Semantic Search ingest key (Bearer for POST /documents / DELETE document). Falls back to SEARCH_API_KEY.
# SEARCH_INGEST_API_KEY=sk_ingest_...

# LLM: Gemini first (Google AI). For local LLM later, set LLM_PROVIDER=openai_compatible + LLM_BASE_URL.
LLM_PROVIDER=gemini
LLM_API_KEY=gemini_key
LLM_MODEL=gemini-2.5-flash
# Optional: OpenAI-compatible endpoint (vLLM, Ollama --api-style openai, etc.) when LLM_PROVIDER=openai_compatible
# LLM_BASE_URL=http://localhost:11434/v1

UPLOAD_DIR=/tmp/cv_uploads
MAX_FILE_SIZE_MB=20
OCR_DPI=300
OCR_CONFIDENCE_THRESHOLD=0.6
FASTTEXT_MODEL_PATH=/models/lid.176.bin

RANKING_DEFAULT_RECALL_SIZE=30
RANKING_LLM_CONCURRENCY=5

# Webhook secrets (HMAC-SHA256 signing)
# Shared secret with Semantic Search for incoming ingestion webhooks
SEARCH_WEBHOOK_SECRET=change_me_search_webhook_secret
# Shared secret with Hiring Platform for outgoing CV status callbacks
HP_WEBHOOK_SECRET=change_me_hp_webhook_secret
WEBHOOK_TIMEOUT_SECONDS=10

