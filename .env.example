# ═══════════════════════════════════════════════════════════════════
# CV Intelligence Layer (this app)
# ═══════════════════════════════════════════════════════════════════
APP_ENV=development
APP_PORT=8001
APP_API_KEY=dev_key_change_me
UPLOAD_DIR=/tmp/cv_uploads
MAX_FILE_SIZE_MB=20
OCR_DPI=150
OCR_CONFIDENCE_THRESHOLD=0.6
# Run EasyOCR on GPU (requires nvidia-container-toolkit on the host).
# CUDA runtime + PyTorch wheels are baked into the Docker image; set to
# false to force CPU.
EASYOCR_GPU=true
FASTTEXT_MODEL_PATH=/models/lid.176.bin
RANKING_DEFAULT_RECALL_SIZE=20
RANKING_LLM_CONCURRENCY=10
MIN_CV_TEXT_CHARS=200

# ═══════════════════════════════════════════════════════════════════
# PostgreSQL + Redis (infrastructure)
# ═══════════════════════════════════════════════════════════════════
DATABASE_URL=postgresql+asyncpg://cv_user:password@localhost:5432/cv_intelligence
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0

# ═══════════════════════════════════════════════════════════════════
# Semantic Search API (external service)
# ═══════════════════════════════════════════════════════════════════
SEARCH_API_BASE_URL=http://localhost:80
SEARCH_API_KEY=search_api_key
# SEARCH_INGEST_API_KEY=sk_ingest_...
SEARCH_WEBHOOK_SECRET=change_me_search_webhook_secret

# ═══════════════════════════════════════════════════════════════════
# LLM — Google Gemini (or OpenAI-compatible local)
# ═══════════════════════════════════════════════════════════════════
LLM_PROVIDER=gemini
LLM_API_KEY=gemini_key
LLM_MODEL=gemini-2.5-flash
# LLM_BASE_URL=http://localhost:11434/v1
# LLM_SSL_VERIFY=false              # Only for TLS-intercepting corporate proxies
# EASYOCR_MODULE_PATH=/opt/easyocr-models  # Custom EasyOCR model directory (disables download)
# Cache the stable extraction-prompt prefix (skills + establishments + languages
# vocabulary, schema, rules) in Gemini context cache. Keyed by the catalog
# fingerprint; recreated when the catalog changes or the TTL lapses.
GEMINI_CACHE_ENABLED=true
GEMINI_CACHE_TTL_SECONDS=3600

# ═══════════════════════════════════════════════════════════════════
# SkillConnect (Ooredoo HR) integration — skills catalog API (no auth)
# ═══════════════════════════════════════════════════════════════════
# SKILLCONNECT_API_BASE_URL=https://elevate.ooredoo.dz/elevate-api
# SKILLCONNECT_SSL_VERIFY=true       # false behind a TLS-intercepting proxy
# SKILLCONNECT_PROXY=http://proxy:8080   # or rely on HTTPS_PROXY/NO_PROXY
SKILLCONNECT_REFRESH_SECONDS=3600

# ═══════════════════════════════════════════════════════════════════
# Hiring Platform (external consumer)
# ═══════════════════════════════════════════════════════════════════
APP_WEBHOOK_SECRET=change_me_app_webhook_secret
WEBHOOK_TIMEOUT_SECONDS=10
